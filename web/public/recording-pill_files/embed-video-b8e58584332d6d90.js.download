    query GetAgentBrief($videoId: ID!) {
  getAgentBrief(videoId: $videoId) {
    __typename
    ... on GetAgentBriefPayload {
      agentBrief {
        videoId
        actions {
          id
          heading
          content
          rationale
          timestamp
          details
          enabled
          createdAt
          updatedAt
        }
      }
    }
    ... on GenericError {
      message
    }
  }
}
