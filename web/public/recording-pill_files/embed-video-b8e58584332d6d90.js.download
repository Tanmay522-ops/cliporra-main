    mutation ContactSupport($subject: String!, $category: String!, $issue: String, $platform: String, $priority: String, $message: String!, $videoUrl: String, $permissionToImpersonate: Boolean!, $chatHistory: String, $userTimezoneOffset: Int, $conversationId: ID) {
  createSupportTicket(
    subject: $subject
    category: $category
    issue: $issue
    platform: $platform
    priority: $priority
    message: $message
    videoUrl: $videoUrl
    permissionToImpersonate: $permissionToImpersonate
    chatHistory: $chatHistory
    userTimezoneOffset: $userTimezoneOffset
    conversationId: $conversationId
  ) {
    ... on CreateSupportTicketPayload {
      success
    }
    ... on GenericError {
      message
    }
  }
}
