    query GetPublishedOrMostRecentVideoDocumentForEditor($videoId: ID!) {
  getPublishedOrMostRecentVideoDocumentForEditor(videoId: $videoId) {
    __typename
    ... on GetPublishedOrMostRecentVideoDocumentForEditorPayload {
      videoDocument {
        id
        documentType
        originalContentJson
        formattedContentMarkdown
        dateVisibleToViewers
        createdAt
        updatedAt
      }
    }
    ... on GenericError {
      message
    }
  }
}
