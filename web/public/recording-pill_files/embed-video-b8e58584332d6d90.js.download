    query ConsolidatedEditGetTranscriptStatus($videoId: ID!, $password: String = null, $captionsLanguageSelection: String = null) {
  fetchVideoTranscript(
    videoId: $videoId
    password: $password
    captionsLanguageSelection: $captionsLanguageSelection
  ) {
    ... on VideoTranscriptDetails {
      idv2
      video_id
      transcription_status
    }
    ... on InvalidRequestWarning {
      message
    }
    ... on GenericError {
      message
    }
  }
}
