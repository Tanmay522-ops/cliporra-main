    query GetPeopleAccess($videoId: ID!) {
  aclResult: getVideoAclEntries(videoId: $videoId) {
    __typename
    ... on GetVideoAclEntriesPayload {
      entrySet {
        peopleEntries {
          __typename
          access
          ... on UserVideoAclEntry {
            user {
              id
            }
          }
          ... on UserEmailVideoAclEntry {
            email
            hasPendingInvite
          }
        }
      }
    }
    ... on UserNotAuthorizedError {
      message
    }
  }
}
