    query GetVideoSSR($id: ID!, $password: String = null) {
  getVideo(id: $id, password: $password) {
    __typename
    ... on PrivateVideo {
      id
      status
      message
      __typename
    }
    ... on VideoPasswordMissingOrIncorrect {
      id
      message
      __typename
    }
    ... on RegularUserVideo {
      id
      __typename
      defaultThumbnails {
        default
        static
        __typename
      }
      signedThumbnails {
        animatedPreview
        default
        default4X3
        defaultPlay
        ogFull
        full
        fullPlay
        defaultGif
        defaultGifPlay
      }
      dashUrl: nullableRawCdnUrl(acceptableMimes: [DASH], password: $password) {
        url
        credentials {
          Policy
          Signature
          KeyPairId
        }
      }
      hlsUrl: nullableRawCdnUrl(acceptableMimes: [M3U8], password: $password) {
        url
        credentials {
          Policy
          Signature
          KeyPairId
        }
      }
