    mutation SetAgentBriefActionEnabled($input: SetAgentBriefActionEnabledInput!) {
  setAgentBriefActionEnabled(input: $input) {
    __typename
    ... on SetAgentBriefActionEnabledPayload {
      agentBriefAction {
        id
        enabled
        updatedAt
      }
    }
    ... on EntityNotFoundError {
      message
    }
    ... on UserNotAuthorizedError {
      message
    }
    ... on GenericError {
      message
    }
