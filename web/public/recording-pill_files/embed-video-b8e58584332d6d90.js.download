    query FetchInvitationCapabilities($workspaceId: ID!, $isOnboarding: Boolean) {
  fetchInvitationCapabilities(
    workspaceId: $workspaceId
    isOnboarding: $isOnboarding
  ) {
    ... on FetchInvitationCapabilitiesPayload {
      id
      domains
      inviteSetting
      inviteFlow
    }
