    mutation CreateAssetUploadCredentials($forceS3: Boolean, $sessionId: ID) {
  createAssetUploadCredentials(forceS3: $forceS3, sessionId: $sessionId) {
    ... on CreateAssetUploadCredentialsPayload {
      __typename
      sessionId
      credentials {
        ... on ObjectStoreInfo {
          hostname
          bucket
          workspaceType
          siteId
          activationId
          token {
            value
            expiration
          }
        }
      }
    }
    ... on UserNotAuthorizedError {
      message
    }
    ... on GenericError {
      message
    }
  }
}
