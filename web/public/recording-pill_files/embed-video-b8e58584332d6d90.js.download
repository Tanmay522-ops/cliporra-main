    query ConsolidatedEditGetAutoTrimStatuses($videoId: ID!, $password: String) {
  getAutoFeatureStatuses(videoId: $videoId, password: $password) {
    ... on AutoFeatureStatuses {
      id
      hasFillerWordRemovalEnabled
      hasFillerWordPlusRemovalEnabled
      hasSilenceRemovalEnabled
      numberOfFillerWordsTrimmed
      numberOfFillerWordsPlusTrimmed
      secondsOfSilenceTrimmed
    }
    ... on Error {
      message
    }
  }
}
    `;let C=(0,f.J1)`
    fragment ConsolidatedEditPhraseFragment on TimestampedPhrase {
  start
  clipId
  tokens {
    value
    start
    end
    type
  }
}
    `;(0,f.J1)`
    query ConsolidatedEditFetchTimestampedWords($videoId: ID!, $password: String) {
  fetchTimestampedWords(videoId: $videoId, password: $password) {
    __typename
    ... on TimestampedWordsPayload {
      transcript {
        phrases {
          ...ConsolidatedEditPhraseFragment
        }
      }
    }
    ... on Warning {
      message
    }
    ... on Error {
      message
    }
  }
}
