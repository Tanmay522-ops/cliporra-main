    query GetKeyTakeaways($videoId: ID!) {
  getKeyTakeaways(videoId: $videoId) {
    ... on GetKeyTakeawaysPayload {
      __typename
      takeaways
    }
    ... on UserNotAuthorizedError {
      message
    }
    ... on GenericError {
      message
      error
    }
    ... on InputValidationError {
      message
      failedFields {
        field
        message
      }
    }
  }
}
