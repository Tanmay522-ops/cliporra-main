  white-space: pre-wrap;
  overflow-wrap: anywhere;
  font-size: ${e=>"small"===e.fontSize?"var(--lns-fontSize-small)":"var(--lns-fontSize-medium)"};
  font-family: var(
    --lns-fontFamily-body,
    Circular,
    Twemoji Mozilla,
    Apple Color Emoji,
    Noto Color Emoji,
    Segoe UI Emoji,
    Segoe UI Symbol,
    Segoe UI,
    EmojiOne Color,
    Android Emoji
  );

  a.comment-link {
    color: var(--lns-color-blurple);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  a.comment-link:focus-visible {
    outline: 2px solid var(--lns-color-blurple);
    outline-offset: 2px;
    border-radius: 2px;
  }
  p {
    margin-block-start: 0;
    margin-block-end: 0;
  }
  blockquote {
    border-left: 3px solid var(--lns-color-border);
    padding-left: var(--lns-space-medium);
    margin-block-start: 0;
    margin-block-end: 0;
    color: var(--lns-color-bodyDimmed);
    font-style: italic;
    white-space: normal;
  }
  blockquote + blockquote {
