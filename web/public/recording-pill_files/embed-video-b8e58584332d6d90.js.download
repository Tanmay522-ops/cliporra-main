  applyFillerWordRemovalTTS(input: {videoId: $videoId, password: $password}) {
    __typename
    ... on ApplyFillerWordRemovalTTSPayload {
      video {
        ...EditTabVideoTrims
      }
    }
    ... on UserNotAuthorizedError {
      message
    }
    ... on Error {
      message
    }
  }
}
